# Variáveis de ambiente para desenvolvimento local
# Copie para .env e ajuste os valores

# Chave de encriptação do kubeconfig (mínimo 32 caracteres)
GREENCAP_ENCRYPTION_KEY=dev-encryption-key-change-me-32x

# Produção: sobrescreva as configurações do banco abaixo
# DB_USER=greencap
# DB_PASSWORD=changeme
# ENCRYPTION_KEY=sua-chave-segura-aqui
